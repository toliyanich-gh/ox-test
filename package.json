{
  "name": "code-guardian",
  "version": "1.0.0",
  "description": "High-performance backend service wrapping Trivy security scanner with stream-based processing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "oom-test": "node --max-old-space-size=150 dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["trivy", "security", "streams", "oom"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "stream-json": "^1.7.6",
    "stream-chain": "^2.2.5",
    "simple-git": "^3.25.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.3",
    "ts-node-dev": "^2.0.0"
  }
}
